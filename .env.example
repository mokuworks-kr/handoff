# =============================================================
# Handoff 환경변수
# 이 파일을 .env.local로 복사하고 실제 값을 채워넣으세요.
# Vercel에는 Project Settings > Environment Variables에서 동일하게 등록.
# =============================================================

# ---- Supabase ----
# Supabase Dashboard > Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# 서버 전용 — 절대 클라이언트에 노출 금지. NEXT_PUBLIC_ 접두사 절대 X.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ---- Anthropic ----
# https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# ---- 사이트 URL (OAuth 콜백 redirect_to에 사용) ----
# 로컬: http://localhost:3000
# 배포 후: https://your-domain.vercel.app (또는 커스텀 도메인)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================
# 마일스톤 1에서는 위 5개만 있으면 됩니다.
# 아래는 다음 마일스톤에서 추가될 것들 (지금은 비워두거나 삭제):
# =============================================================
# TOSSPAYMENTS_CLIENT_KEY=
# TOSSPAYMENTS_SECRET_KEY=
# UNSPLASH_ACCESS_KEY=
